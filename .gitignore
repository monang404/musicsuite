# ============================================================
# Music Suite — .gitignore
# ============================================================

# Python bytecode
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Virtual environments
.venv/
venv/
env/
.env

# Distribution / packaging
dist/
build/
*.egg-info/
*.spec

# Database (user data — never commit)
data/*.db
data/*.db-shm
data/*.db-wal

# Logs & debug output
*.log
debug/*.json
debug/*.md

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# IDE
.idea/
.vscode/
*.swp

# Temp / partial downloads
*.part
*.ytdl
*.temp

# PyInstaller output
output/

# Test coverage
.coverage
htmlcov/
.pytest_cache/